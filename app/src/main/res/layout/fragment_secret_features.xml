<!-- app/src/main/res/layout/fragment_secret_features.xml -->

<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Статус: "
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="8dp"
            android:background="#FF4081"
            android:textColor="#FFFFFF"
            android:gravity="center" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Управление через Intent"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_custom_command"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Введите стратегию (напр: -f-1 -Qr -s1+sm -a1)"
            android:inputType="textMultiLine"
            android:minLines="2"
            android:maxLines="4"
            android:background="@android:drawable/editbox_background"
            android:padding="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btn_send_intent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Intent"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btn_quick_toggle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Применить"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Продвинутое управление"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_force_close"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💀 Принудительно закрыть прокси (jniForceClose)"
            android:layout_marginBottom="4dp" />

        <Button
            android:id="@+id/btn_debug_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🐛 Включить DEBUG режим (--debug)"
            android:layout_marginBottom="4dp" />

        <Button
            android:id="@+id/btn_list_substitution"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📋 Подстановка {list:имя}"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Тестирование и диагностика"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_test_all_strategies"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🧪 Подбор стратегий (TestActivity)"
            android:layout_marginBottom="4dp" />

        <Button
            android:id="@+id/btn_dump_logs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📱 Полный дамп (logcat + dmesg)"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Резервное копирование"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_export_full"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📤 Экспорт ВСЕГО"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btn_import_full"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📥 Импорт ВСЕГО"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠️ Внимание: Эти функции для продвинутых пользователей!\nНеправильное использование может привести к нестабильной работе."
            android:textSize="12sp"
            android:textColor="#FF9800"
            android:layout_marginTop="24dp"
            android:gravity="center" />

    </LinearLayout>
</ScrollView>
