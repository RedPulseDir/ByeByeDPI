<resources>
    <style name="Theme.ByeDPI" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">#5976DF</item>
        <item name="colorPrimaryVariant">#3C52A3</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#5976DF</item>
        <item name="colorSecondaryVariant">#3C52A3</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="android:statusBarColor">#3C52A3</item>
        <item name="colorSurface">#F5F5F5</item>
        <item name="colorOnSurface">#212121</item>
        <item name="materialCardViewStyle">@style/SmallShadowCard</item>
    </style>

    <style name="SmallShadowCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardElevation">1dp</item>
    </style>

    <style name="CircleButton" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">60dp</item>
        <item name="android:textSize">0sp</item>
        <item name="backgroundTint">?attr/colorPrimary</item>
        <item name="iconTint">?attr/colorOnPrimary</item>
    </style>

    <style name="CustomAlertDialog" parent="ThemeOverlay.MaterialComponents.Dialog.Alert">
        <!-- Custom dialog styles -->
    </style>

    <!-- TV Theme -->
    <style name="Theme.ByeDPI.Leanback" parent="Theme.Leanback">
        <item name="colorPrimary">#5976DF</item>
        <item name="colorPrimaryDark">#3C52A3</item>
        <item name="colorAccent">#5976DF</item>
        <item name="android:windowBackground">@color/lb_background</item>
        <item name="android:colorBackground">@color/lb_background</item>
    </style>

    <color name="lb_background">#0F0F0F</color>
    <color name="lb_card_selected">#5976DF</color>
</resources>
